# ============================================================================
# AG Associates AI — Frontend Environment Variables
# ============================================================================
# Copy this file to `.env.local` and adjust for your environment.
# `.env*` files are gitignored; never commit real secrets.

# Public API URL — inlined into the client bundle at build time.
# Used by browser-side fetches in app/dashboard/page.tsx.
NEXT_PUBLIC_API_URL=http://localhost:8001

# Server-side API URL — used by server components / route handlers.
# Inside Docker this is typically http://backend:8001 or
# http://host.docker.internal:8001. Falls back to NEXT_PUBLIC_API_URL when unset.
API_URL=http://localhost:8001
