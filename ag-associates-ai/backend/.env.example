# ============================================================================
# AG Associates AI — Backend Environment Variables
# ============================================================================
# Copy this file to `.env` and fill in the values for your environment.
# `.env` is gitignored; never commit real secrets.

# ----------------------------------------------------------------------------
# Database (PostgreSQL + pgvector)
# ----------------------------------------------------------------------------
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=legal_templates_db
DATABASE_USER=ag_admin
DATABASE_PASSWORD=change_me

# ----------------------------------------------------------------------------
# LLM (vLLM / OpenAI-compatible endpoint)
# ----------------------------------------------------------------------------
LLM_BASE_URL=http://localhost:8000/v1
LLM_MODEL_NAME=qwen2.5-7b-instruct
# When true, agents skip live LLM calls and return canned responses.
# Useful for local dev / CI without a running vLLM server.
LLM_MOCK_MODE=false

# ----------------------------------------------------------------------------
# Embedding model
# ----------------------------------------------------------------------------
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# Must match the `vector(N)` dimension declared in database/init.sql.
EMBEDDING_DIMENSION=384

# ----------------------------------------------------------------------------
# Output / PDF generation
# ----------------------------------------------------------------------------
OUTPUT_DIR=./output
PDF_ENABLED=false

# ----------------------------------------------------------------------------
# FastAPI server
# ----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8001
# Comma-separated list of allowed origins for CORS, or `*` for all.
CORS_ALLOWED_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# NeSL mock filing
# ----------------------------------------------------------------------------
# Simulated processing delay (seconds) for POST /api/nesl/execute.
NESL_MOCK_DELAY_SEC=3
