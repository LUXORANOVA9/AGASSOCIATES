# ============================================================================
# AG Associates AI — Docker Compose Environment Variables
# ============================================================================
# Copy to `.env` next to docker-compose.yml. Values here are interpolated into
# the compose file at `docker-compose up` time.
# `.env` is gitignored; never commit real secrets.

# ----------------------------------------------------------------------------
# PostgreSQL container
# ----------------------------------------------------------------------------
POSTGRES_USER=ag_admin
POSTGRES_PASSWORD=change_me
POSTGRES_DB=legal_templates_db

# ----------------------------------------------------------------------------
# n8n container
# ----------------------------------------------------------------------------
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me
N8N_HOST=localhost
# Public webhook URL n8n advertises to external services (e.g. WhatsApp).
# In production set to your tunnel/public hostname, e.g. https://n8n.example.com/
WEBHOOK_URL=http://localhost:5678/

# ----------------------------------------------------------------------------
# WhatsApp Business Cloud API (used by n8n nodes / backend webhook handler)
# ----------------------------------------------------------------------------
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
# Verify token used during webhook subscription handshake.
WHATSAPP_VERIFY_TOKEN=
