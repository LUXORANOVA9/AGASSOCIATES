# ============================================================
# AG ASSOCIATES MONOREPO — ENVIRONMENT VARIABLES
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# --- Supabase (apps/web, apps/bank-portal, apps/legacy-web) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- AI / Google (apps/web, packages/ai) ---
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key
RESEND_API_KEY=re_your_resend_key

# --- Database (direct pg connection for apps/legacy-web) ---
DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_POSTGRESDB_HOST=localhost
DB_POSTGRESDB_USER=postgres
DB_POSTGRESDB_PASSWORD=CHANGE_ME
DB_POSTGRESDB_DATABASE=ag_associates

# --- AI Backend (services/ai-backend) ---
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=legal_templates_db
DATABASE_USER=ag_admin
DATABASE_PASSWORD=CHANGE_ME_IN_PRODUCTION
LLM_BASE_URL=http://localhost:8000/v1
LLM_MODEL_NAME=qwen2.5-7b-instruct
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
OUTPUT_DIR=./output
PDF_ENABLED=false
API_HOST=0.0.0.0
API_PORT=8001

# --- AI Dashboard (apps/ai-dashboard) ---
NEXT_PUBLIC_API_URL=http://localhost:8001

# --- n8n ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME
